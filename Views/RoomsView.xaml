<UserControl x:Class="SmartHouseApp.Views.RoomsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#1E1E2E">

     <Grid Margin="30">

          <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Header -->

          <StackPanel Orientation="Horizontal">

               <TextBlock Text="Rooms"
                       FontSize="28"
                       Foreground="White"
                       Margin="0,0,20,0"/>

               <Button Name="AddRoomBtn"
                    Content="Add Room"
                    Width="120"
                    Height="35"/>

               <Button Name="DeleteRoomBtn"
                    Content="Delete Room"
                    Width="120"
                    Height="35"
                    Margin="10,0,0,0"/>

          </StackPanel>

          <!-- Lista camerelor -->

          <ListBox Name="RoomsList"
                 Grid.Row="1"
                 Margin="0,20,0,0"
                 FontSize="18"/>

     </Grid>

</UserControl>