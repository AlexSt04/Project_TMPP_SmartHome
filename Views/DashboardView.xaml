<UserControl x:Class="SmartHouseApp.Views.DashboardView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

     <Grid Margin="30">

          <StackPanel>

               <TextBlock Text="Smart Home Dashboard"
FontSize="28"
Margin="0 0 0 20"/>

               <WrapPanel>

                    <materialDesign:Card Padding="20" Margin="10" Width="200">

                         <StackPanel>
                              <TextBlock Text="Rooms"/>
                              <TextBlock Name="RoomCount"
FontSize="30"
FontWeight="Bold"/>
                         </StackPanel>

                    </materialDesign:Card>

                    <materialDesign:Card Padding="20" Margin="10" Width="200">

                         <StackPanel>
                              <TextBlock Text="Devices"/>
                              <TextBlock Name="DeviceCount"
FontSize="30"
FontWeight="Bold"/>
                         </StackPanel>

                    </materialDesign:Card>

               </WrapPanel>

          </StackPanel>

     </Grid>
</UserControl>