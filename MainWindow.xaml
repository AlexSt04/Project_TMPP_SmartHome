<Window x:Class="SmartHouseApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Smart Home"
        Height="600"
        Width="1000">

     <Grid>

          <Grid.ColumnDefinitions>
               <ColumnDefinition Width="200"/>
               <ColumnDefinition Width="609*"/>
               <ColumnDefinition Width="191*"/>
          </Grid.ColumnDefinitions>

          <!-- Sidebar -->

          <StackPanel Background="#263238">

               <TextBlock Text="SMART HOME"
                   Foreground="White"
                   FontSize="22"
                   Margin="20"
                   FontWeight="Bold"/>

               <Button Name="DashboardBtn"
                Content="Dashboard"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Margin="10"
                Height="40"/>

               <Button Name="RoomsBtn"
                Content="Rooms"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Margin="10"
                Height="40"/>

               <Button Name="DevicesBtn"
                Content="Devices"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Margin="10"
                Height="40"/>

          </StackPanel>

          <!-- Main Area -->

          <Grid Grid.Column="1" Grid.ColumnSpan="2">

               <Grid Grid.Column="1">

                    <ContentControl Name="MainContent"/>

               </Grid>

               <StackPanel Margin="30">

                    <TextBlock Text="Dashboard"
                           FontSize="28"
                           Foreground="White"
                           Margin="0 0 0 20"/>

                    <WrapPanel>

                         <Border Background="#3A3A55"
                            Width="200"
                            Height="120"
                            Margin="10"
                            CornerRadius="10">

                              <StackPanel VerticalAlignment="Center">

                                   <TextBlock Text="Rooms"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>

                                   <TextBlock Name="RoomCount"
                                       FontSize="24"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>

                              </StackPanel>

                         </Border>

                         <Border Background="#3A3A55"
                            Width="200"
                            Height="120"
                            Margin="10"
                            CornerRadius="10">

                              <StackPanel VerticalAlignment="Center">

                                   <TextBlock Text="Devices"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>

                                   <TextBlock Name="DeviceCount"
                                       FontSize="24"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>

                              </StackPanel>

                         </Border>

                    </WrapPanel>

               </StackPanel>

          </Grid>

     </Grid>
</Window>